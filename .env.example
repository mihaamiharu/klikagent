PORT=3000

# GitHub
GITHUB_TOKEN=your_github_pat_here          # needs: contents r/w, pull-requests r/w, issues read, actions r/w
GITHUB_OWNER=your_github_username_or_org
GH_MAIN_REPO=your-dev-repo               # repo where source issues live

# Self-correction loop
MAX_SELF_CORRECTION_ATTEMPTS=2

# AI (Minimax or any OpenAI-compatible provider)
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.minimax.io/v1
AI_MODEL=MiniMax-M2.7
AI_MAX_ITERATIONS=50

# Crawler — QA environment the enrichment agent crawls
QA_BASE_URL=https://your-qa-environment.com

# Personas — loaded from env vars directly
# Default persona
QA_USER_EMAIL=user@example.com
QA_USER_PASSWORD=Password123!
# Additional personas: PERSONA_<NAME>_EMAIL / PERSONA_<NAME>_PASSWORD
# PERSONA_ADMIN_EMAIL=admin@example.com
# PERSONA_ADMIN_PASSWORD=Password123!

# Dashboard
DASHBOARD_PASSWORD=your_dashboard_password_here
DASHBOARD_PERSIST=true
